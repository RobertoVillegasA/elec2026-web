# ============================================
# Sistema Electoral Bolivia 2026 - Variables de Entorno
# ============================================
# Copia este archivo como .env y ajusta los valores
# ============================================

# ============================================
# BASE DE DATOS
# ============================================
# Para Railway (variables automáticas):
# MYSQLHOST, MYSQLUSER, MYSQLPASSWORD, MYSQLDATABASE, MYSQLPORT se crean automáticamente

# Para Render/otros servidores:
DB_HOST=localhost
DB_PORT=3306
DB_NAME=sistema_electoral
DB_USER=root
DB_PASSWORD=tu_password

# URL de conexión directa (alternativa)
# DATABASE_URL=mysql://user:password@host:3306/dbname

# ============================================
# SEGURIDAD
# ============================================
# Genera una clave segura con: python -c "import secrets; print(secrets.token_urlsafe(32))"
# En Railway/Render usa un generador online o el comando anterior
SECRET_KEY=tu_clave_secreta_muy_larga_y_segura_cambia_esto_en_produccion

# ============================================
# CORS (Orígenes permitidos)
# ============================================
# Separa múltiples orígenes con comas
# Para Railway: https://tu-proyecto.up.railway.app
# Para Render: https://tu-proyecto.onrender.com
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Para producción, usa tu dominio real:
# CORS_ORIGIN=https://tu-dominio.com

# ============================================
# GOOGLE DRIVE API (Opcional - para carga de imágenes)
# ============================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_DRIVE_FOLDER_ID=

# ============================================
# ONEDRIVE API (Opcional)
# ============================================
ONE_DRIVE_CLIENT_ID=
ONE_DRIVE_CLIENT_SECRET=
ONE_DRIVE_TENANT_ID=

# ============================================
# CONFIGURACIÓN DE LA APLICACIÓN
# ============================================
APP_NAME=Sistema Electoral Bolivia 2026
DEBUG=false
LOG_LEVEL=INFO

# ============================================
# PUERTO (para servidores que lo requieran)
# ============================================
PORT=8000

# ============================================
# LÍMITES Y TIEMPOS DE ESPERA
# ============================================
MAX_UPLOAD_SIZE=10485760
REQUEST_TIMEOUT=30
