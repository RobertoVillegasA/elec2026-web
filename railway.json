{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "gunicorn web:app --worker-class uvicorn.workers.UvicornWorker --workers 2 --threads 4 --worker-tmp-dir /dev/shm --bind 0.0.0.0:$PORT",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "env": {
      "PORT": "8000",
      "RAILWAY_ENVIRONMENT": "production",
      "PYTHON_VERSION": "3.11"
    }
  }
}
