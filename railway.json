{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "python web.py",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "env": {
      "PORT": "8000",
      "RAILWAY_ENVIRONMENT": "production",
      "PYTHONUNBUFFERED": "1"
    }
  }
}
